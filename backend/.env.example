# Database — Supabase Postgres connection string (use asyncpg driver)
DATABASE_URL=postgresql+asyncpg://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# JWT signing secret — generate with: openssl rand -hex 32
JWT_SECRET=your-jwt-secret-here

# AES-256-GCM key for encrypting platform credentials (must be exactly 32 chars)
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(24))"
CREDENTIAL_ENCRYPTION_KEY=your-32-char-encryption-key-here!

# Google OAuth 2.0 (for social login)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Twitter/X OAuth 2.0 PKCE
# Register https://personnapress.com/api/auth/x/callback in Twitter Dev Portal → App → Auth settings
X_CLIENT_ID=your-x-client-id
X_CLIENT_SECRET=your-x-client-secret
X_REDIRECT_URI=https://personnapress.com/api/auth/x/callback

# LinkedIn OAuth 2.0
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
LINKEDIN_REDIRECT_URI=https://personnapress.com/api/auth/linkedin/callback

# WordPress.com OAuth 2.0
WP_COM_CLIENT_ID=your-wordpress-com-app-id
WP_COM_CLIENT_SECRET=your-wordpress-com-client-secret
WP_COM_REDIRECT_URI=https://personnapress.com/api/auth/wordpress-com/callback

# Stripe (billing)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_live_...
STRIPE_PRICE_GROWTH=price_live_...   # Growth $49/mo recurring — create new price in Stripe Dashboard
STRIPE_PRICE_AGENCY=price_live_...   # Agency $149/mo recurring — create new price in Stripe Dashboard

# AI services
GEMINI_API_KEY=your-gemini-api-key
# Gemini model to use for all AI calls. Default: gemini-2.5-flash (fast + cheap).
# Upgrade to gemini-2.5-pro for higher quality output at higher cost.
# Verify available model IDs at: https://ai.google.dev/models
GEMINI_MODEL=gemini-2.5-flash
REPLICATE_API_TOKEN=r8_...

# Observability
# Get from sentry.io — required for production error tracking
SENTRY_DSN=

# Email (Resend)
RESEND_API_KEY=re_...
# Format must be: "Name <address@domain.com>" — quotes required when sourcing in shell
EMAIL_FROM="PersonnaPress <noreply@personnapress.com>"

# Frontend origin for CORS and OAuth redirect URI construction
# CRITICAL: Must exactly match APP_URL in the frontend .env — including protocol and no trailing slash.
# Used by FastAPI to reconstruct redirect_uri for OAuth token exchange.
APP_URL=https://personnapress.com

# Supabase Storage (for brand content files)
SUPABASE_URL=https://your-project.supabase.co
# WARNING: Service role key bypasses Row Level Security — never expose in client-side code or commit to source control
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Trial period (days)
TRIAL_DAYS=14

# GitHub App (for GitHub Pages blog publishing)
# Register at: https://github.com/settings/apps/new
# Callback URL: https://personnapress.com/api/auth/github/callback
GITHUB_APP_ID=your-numeric-app-id
GITHUB_APP_CLIENT_ID=Iv1.your-string-client-id
# PEM private key — generate in App settings → "Generate a private key"
# Paste the full PEM content (include header/footer lines) or base64-encode it
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_APP_WEBHOOK_SECRET=your-webhook-secret

# Backend API base URL (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Stripe publishable key (safe to expose — never use secret key here)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# JWT secret for server-side token verification in middleware
# NEVER prefix with NEXT_PUBLIC_ — this must remain server-only
JWT_SECRET=your-jwt-secret-here

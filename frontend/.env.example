# Public app URL — must match APP_URL in backend .env
NEXT_PUBLIC_APP_URL=https://personnapress.com

# Backend API base URL (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Backend URL used server-side only (Next.js API routes / middleware)
BACKEND_URL=http://localhost:8000

# App URL for server-side OAuth redirect URI construction (Next.js API routes only — never NEXT_PUBLIC_)
# CRITICAL: This must exactly match APP_URL in the backend .env — including protocol and no trailing slash.
APP_URL=http://localhost:3000

# Stripe publishable key (safe to expose — never use secret key here)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# JWT secret for server-side token verification in middleware
# NEVER prefix with NEXT_PUBLIC_ — this must remain server-only
JWT_SECRET=your-jwt-secret-here

# Google OAuth (client_id is safe to expose; secret is server-only)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# WordPress.com OAuth (client_id used server-side to build the authorize URL; secret lives in backend .env only)
WP_COM_CLIENT_ID=your-wordpress-com-app-id

# Twitter/X OAuth 2.0 PKCE (client_id is safe to expose; secret is server-only)
# Register https://personnapress.com/api/auth/x/callback in Twitter Dev Portal → App → Auth settings
NEXT_PUBLIC_X_CLIENT_ID=your-x-oauth-client-id
X_CLIENT_SECRET=your-x-client-secret

# LinkedIn OAuth 2.0 (client_id is safe to expose; secret is server-only)
NEXT_PUBLIC_LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret

# Public app URL — must match APP_URL in backend .env (use https://personnapress.com for production)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Backend API URL (FastAPI running on DigitalOcean Droplet or locally)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Delivery token for the PersonnaPress company blog (create one in Settings → API Tokens; must be a read-only delivery token)
PERSONNAPRESS_DELIVERY_TOKEN=
